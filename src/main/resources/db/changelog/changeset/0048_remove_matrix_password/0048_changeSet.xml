<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <changeSet author="caritas" id="removeMatrixPasswordFromUser">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="user" columnName="matrix_password"/>
    </preConditions>
    <dropColumn tableName="user" columnName="matrix_password"/>
  </changeSet>

  <changeSet author="caritas" id="removeMatrixPasswordFromConsultant">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="consultant" columnName="matrix_password"/>
    </preConditions>
    <dropColumn tableName="consultant" columnName="matrix_password"/>
  </changeSet>
</databaseChangeLog>
