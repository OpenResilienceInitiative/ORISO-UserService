<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="oriso" id="dropMatrixPasswordColumns">
    <preConditions onFail="MARK_RAN">
      <or>
        <columnExists tableName="user" columnName="matrix_password"/>
        <columnExists tableName="consultant" columnName="matrix_password"/>
      </or>
    </preConditions>
    <sqlFile path="db/changelog/changeset/0054_drop_matrix_password/dropMatrixPasswordColumns.sql"
      stripComments="true"/>
    <rollback>
      <comment>Intentional no-op: matrix_password backup rename must not be reversed automatically.</comment>
    </rollback>
  </changeSet>
</databaseChangeLog>
